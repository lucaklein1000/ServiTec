<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <View
        android:id="@+id/vistaMesa"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="#1E3A8A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp"/>

    <View
        android:id="@+id/sillaIzquierda"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/ico_cercle"
        app:layout_constraintTop_toTopOf="@id/vistaMesa"
        app:layout_constraintBottom_toBottomOf="@id/vistaMesa"
        app:layout_constraintEnd_toStartOf="@id/vistaMesa"
        android:layout_marginEnd="4dp"/>

    <View
        android:id="@+id/sillaDerecha"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/ico_cercle"
        app:layout_constraintTop_toTopOf="@id/vistaMesa"
        app:layout_constraintBottom_toBottomOf="@id/vistaMesa"
        app:layout_constraintStart_toEndOf="@id/vistaMesa"
        android:layout_marginStart="4dp"/>

    <View
        android:id="@+id/sillaArriba"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/ico_cercle"
        app:layout_constraintStart_toStartOf="@id/vistaMesa"
        app:layout_constraintEnd_toEndOf="@id/vistaMesa"
        app:layout_constraintBottom_toTopOf="@id/vistaMesa"
        android:layout_marginBottom="4dp"/>

    <View
        android:id="@+id/sillaAbajo"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/ico_cercle"
        app:layout_constraintStart_toStartOf="@id/vistaMesa"
        app:layout_constraintEnd_toEndOf="@id/vistaMesa"
        app:layout_constraintTop_toBottomOf="@id/vistaMesa"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvNumeroTaula"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="T.1"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/vistaMesa"
        app:layout_constraintBottom_toBottomOf="@id/vistaMesa"
        app:layout_constraintStart_toStartOf="@id/vistaMesa"
        app:layout_constraintEnd_toEndOf="@id/vistaMesa"/>

</androidx.constraintlayout.widget.ConstraintLayout>